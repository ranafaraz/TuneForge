# TuneForge runs fully offline by default (numpy only). Everything below is
# OPTIONAL. Copy to `.env` to change the default experiment.

# --- Optimizer (the algorithm under test) ---
# random             (baseline: uniform random search) |
# tpe                (model-based: Tree-structured Parzen Estimator) |
# gp_ei              (model-based: Gaussian process + Expected Improvement) |
# successive_halving (multi-fidelity: one bracket of successive halving) |
# hyperband          (multi-fidelity: Hyperband over several SH brackets)
TUNEFORGE_OPTIMIZER=tpe

# --- Response surface (analytic, with a KNOWN global optimum) ---
# branin   (default, smooth 2-D, structure model-based search can exploit) |
# ackley   (rugged but structured: one global basin under many local dips) |
# null     (ablation: shuffled/unstructured -- no exploitable structure)
TUNEFORGE_SURFACE=branin

# --- Fidelity regime (only affects the multi-fidelity optimizers) ---
# correlated   (default: cheap low-fidelity proxy is rank-correlated with truth) |
# decorrelated (ablation: low-fidelity rank order is independent of the truth)
TUNEFORGE_FIDELITY=correlated

# --- Tunables (deterministic; tweak for experiments) ---
# TUNEFORGE_BUDGET=60        # total full-fidelity-equivalent evaluations
# TUNEFORGE_SEED=0

# --- Optional cross-check backend ---
# Install with: pip install "tuneforge[optuna]"
# Re-runs TPE / successive-halving with Optuna's sampler / pruner to confirm
# the ranking against random search agrees.
# TUNEFORGE_BACKEND=numpy    # numpy (default) | optuna
